.DS_Store
**/.DS_Store

# Internal audit-tooling output — lives under ~/git-reports/audit/<jvd>/
**/_audit_findings.json
**/_taxonomy.*.json
**/_topology_registry.json

# Stray literal "~" scratch dirs (tools passing ~/ literally instead of $HOME).
# Real scratch lives under the actual ~/git-tmp; never inside the repo.
/~/
**/~/
# Python virtualenvs & caches (local dev only — must never be committed)
.venv/
**/.venv/
__pycache__/
**/__pycache__/
*.pyc
